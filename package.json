{
  "name": "devseeker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "edu": "json-server -p 3001 --watch db1.json",
    "exp": "json-server -p 3002 --watch db2.json",
    "gall": "json-server -p 3003 --watch db3.json",
    "build": "vite build && node build/php_env_replace.js --mode=production",
    "build:dev": "vite build --mode development && node build/php_env_replace.js --mode=development",
    "docker:dev": "docker compose -f server/docker-compose.yml --env-file .env.development up -d --build",
    "docker:prod": "docker compose -f server/docker-compose.yml --env-file .env.production up -d --build",
    "docker:down": "docker compose -f server/docker-compose.yml down",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bootstrap": "^5.3.3",
    "dotenv": "^16.4.5",
    "json-server": "^0.17.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^9.10.2",
    "react-router-dom": "^6.23.1",
    "react-slick": "^0.30.2",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "vite": "^7.3.1"
  }
}
